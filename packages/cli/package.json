{
  "name": "@fateline/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "fateline-validate": "./dist/bin.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@fateline/engine": "workspace:*",
    "@fateline/module-io": "workspace:*",
    "@fateline/module-schema": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.9"
  }
}
