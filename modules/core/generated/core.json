          {
            "text": "Accept the demanding, high-paying role",
            "conditions": [],
            "outcomes": [
              {
                "weight": 100,
                "effects": [
                  {
                    "asset": "money",
                    "op": "+",
                    "value": 40000
                  },
                  {
                    "stat": "happiness",
                    "op": "-",
                    "value": 6
                  },
                  {
                    "stat": "health",
                    "op": "-",
                    "value": 4
                  }
                ],
                "resultText": "The money is great, but the hours are brutal."
              }
            ]
          },
          {
            "text": "Take the relaxed, modest role",
            "conditions": [],
            "outcomes": [
              {
                "weight": 100,
                "effects": [
                  {
                    "asset": "money",
                    "op": "+",
                    "value": 18000
                  },
                  {
                    "stat": "happiness",
                    "op": "+",
                    "value": 5
                  }
                ],
                "resultText": "A comfortable balance of work and life."
              }
            ]
          }
        ]
      },
