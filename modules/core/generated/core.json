              {
                "weight": 100,
                "effects": [
                  {
                    "stat": "health",
                    "op": "-",
                    "value": 2
                  },
                  {
                    "stat": "happiness",
                    "op": "+",
                    "value": 2
                  }
                ],
                "resultText": "Relaxing, if not exactly healthy."
