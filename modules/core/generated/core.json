        "id": "evt.job-offer",
        "category": "adult",
        "weight": 12,
        "conditions": [
          {
            "stat": "age",
            "op": ">=",
            "value": 20
          },
          {
            "stat": "age",
            "op": "<=",
            "value": 64
          }
