{
  "manifest": {
    "id": "com.fateline.core",
    "name": "Fateline Core",
    "version": "0.1.0",
    "engineVersion": ">=0.0.0 <1.0.0",
    "author": "Fateline",
    "description": "The base game, shipped as a module. Defines the core stats and a starter set of life events across childhood, adolescence, and adulthood. Everything here uses the same public schema any community module uses (README §8).",
    "dependencies": []
  },
  "content": {
    "stats": [
      {
        "id": "health",
        "label": "Health",
        "min": 0,
        "max": 100,
        "default": 100,
        "showInUI": true,
        "yearlyDelta": 0,
        "exposeAs": "health"
      },
      {
        "id": "happiness",
        "label": "Happiness",
        "min": 0,
        "max": 100,
        "default": 60,
        "showInUI": true,
        "yearlyDelta": 0,
        "exposeAs": "happiness"
      },
      {
        "id": "smarts",
        "label": "Smarts",
        "min": 0,
        "max": 100,
        "default": 50,
        "showInUI": true,
        "yearlyDelta": 0,
        "exposeAs": "smarts"
      },
      {
        "id": "looks",
        "label": "Looks",
        "min": 0,
        "max": 100,
        "default": 50,
        "showInUI": true,
        "yearlyDelta": 0,
        "exposeAs": "looks"
      }
